# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL="postgres://libiamo_user:ShouldContainCapSmallNum123@localhost:5432/libiamo_db"
SQLX_OFFLINE=false

# ============================================================================
# Server Configuration
# ============================================================================
ADDRESS="127.0.0.1:8090"
RUST_LOG="info,libiamo=debug"
NO_COLOR=

# ============================================================================
# Authentication Token Configuration
# ============================================================================
# Token expiration duration in hours (default: 24 hours)
TOKEN_EXPIRATION_HOURS=24

# ============================================================================
# Email Verification Configuration
# ============================================================================
# SMTP server credentials for sending verification emails
# For Gmail: Use app-specific password from https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="ShouldContainCapSmallNum123"
FROM_EMAIL="noreply@libiamo.com"

# Frontend URL for email verification links
FRONTEND_URL="http://localhost:5173"
